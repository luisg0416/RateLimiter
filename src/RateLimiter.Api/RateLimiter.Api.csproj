<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>  <!-- Enforce nullable reference types — catches null bugs at compile time. -->
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>   <!-- Treat all compiler warnings as errors in Release builds. Keeps the codebase clean as it grows. May have to get rid of -->
    <ImplicitUsings>enable</ImplicitUsings>  <!-- Implicit usings: automatically includes common namespaces like System -->
    <AssemblyVersion>1.0.0</AssemblyVersion>
    <FileVersion>1.0.0</FileVersion>
  </PropertyGroup>

    <ItemGroup>
    <PackageReference Include="StackExchange.Redis" Version="2.12.14" />
    <PackageReference Include="Microsoft.Extensions.Caching.StackExchangeRedis" Version="10.0.5" />
    <PackageReference Include="Swashbuckle.AspNetCore" Version="10.1.7" />
  </ItemGroup>

</Project>
